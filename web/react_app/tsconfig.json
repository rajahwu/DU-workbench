{
    "compilerOptions": {
        "target": "ES2022",
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "jsx": "react-jsx",
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "types": [
            "vite/client"
        ],
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/*"
            ],
            "@data/*": [
                "../../data/*"
            ],
            "@features/*": [
                "src/features/*"
            ],
            "@components/*": [
                "src/components/*"
            ],
            "@app/*": [
                "src/app/*"
            ]
        }
    },
    "include": [
        "src",
        "src/PhaseRouterBridge.ts",
        "src/features/SelectShell/index.tsx",
        "../react_app/*.ts",
        "../react_app/*.tsx"
    ],
}